@model Someren.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<h1>Edit Student</h1>

<form action="/Students/Edit" method="post">
    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="text-danger">@ViewData["ErrorMessage"]</div>
    }
    <input type="hidden" name="StudentID" value="@Model.StudentID" />
    <div class="mb-3">
        <label class="form-label">Student number</label>
        <input type="text" name="StudentNumber" value="@Model.StudentNumber" class="form-control" />
        @if (ViewData["StudentNumberError"] != null)
        {
            <div class="text-danger">@ViewData["StudentNumberError"]</div>
        }
    </div>
    <div class="mb-3">
        <label class="form-label">First name</label>
        <input type="text" name="FirstName" value="@Model.FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Last name</label>
        <input type="text" name="LastName" value="@Model.LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Phone number</label>
        <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Class</label>
        <input type="text" name="Class" value="@Model.Class" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Room</label>
        <select name="RoomID" class="form-select">
            @foreach (var room in (IEnumerable<dynamic>)ViewData["RoomOptions"])
            {
                if (Model.RoomID.HasValue && room.Value == Model.RoomID.Value.ToString())
                {
                    <option value="@room.Value" selected>@room.Text</option>
                }
                else
                {
                    <option value="@room.Value">@room.Text</option>
                }
            }
        </select>
    </div>
    <input type="submit" value="Edit" />
    <a href="/Students">Back</a>
</form>
