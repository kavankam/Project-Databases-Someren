@model List<Someren.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h1>Students</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<form action="/Students" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by last name" />
        </div>
        <div class="col-md-2">
            <input type="submit" value="Search" />
            <a href="/Students">Clear</a>
        </div>
    </div>
</form>

<p>
    <a href="/Students/Create">Add New Student</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Student Number</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Telephone Number</th>
        <th>Class</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var student in Model)
    {
        <tr>
            <td>@student.StudentNumber</td>
            <td>@student.FirstName</td>
            <td>@student.LastName</td>
            <td>@student.PhoneNumber</td>
            <td>@student.Class</td>
            <td>
                <a href="/Students/Edit/@student.StudentID">Edit</a>
                <a href="/Students/Delete/@student.StudentID">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>