@model Someren.Models.Lecturer

@{
    ViewData["Title"] = "Create Lecturer";
}

<h2>Add Lecturer</h2>

<form action="/Lecturers/Create" method="post">    
    <div class="form-group py-2">
        <label for="FirstName"> First Name:</label>
        <input type="text" name="FirstName" value="@(Model?.FirstName)" class="form-control" />
    </div>
    
    <div class="form-group py-2">
        <label for="LastName"> Last Name:</label>
        <input type="text" name="LastName" value="@(Model?.LastName)" class="form-control" />
    </div>
    
    <div class="form-group py-2">
        <label for="PhoneNumber"> Phone Number:</label>
        <input type="text" name="PhoneNumber" value="@(Model?.PhoneNumber)" class="form-control" />
    </div>

    <div class="form-group py-2">
        <label for="Age"> Age:</label>
        <input type="number" name="Age" value="@(Model?.Age)" class="form-control" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary me-2">Add</button>
        <a href="/Lecturers/Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>