@model Someren.Models.Lecturer

@{
    ViewData["Title"] = "Delete Lecturer";
}

<h2>Delete Lecturer</h2>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="LecturerID" />
    <input hidden type="number" name="LecturerID" value="@Model?.LecturerID"/>

    <div class="form-group py-2">
        <label for="UserName">First Name:</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="form-group py-2">
        <label for="UserName">Last Name:</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="form-group py-2">
        <label for="MobileNumber">Phone Number:</label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>
    
    <div class="form-group py-2">
        <label for="Age"> Age:</label>
        <input asp-for="Age" type="number" class="form-control" />
    </div>
    
    <div class="mt-3">
        <button type="submit" class="btn btn-primary me-2">Delete</button>
        <a href="/Lecturers/Index" class="btn btn-secondary">Back to List</a>
    </div>

</form>