@model List<Someren.Models.Lecturer>

@{
    ViewData["Title"] = "Lecturers";
}

<h1>Lecturers</h1>

<a href="/Lecturers/Create" class="btn btn-primary">Add Lecturer</a>

<table class="table">
    <thead>

    <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Phone Number</th>
        <th>Age</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var lecturer in Model)
    {
        <tr>
            <td>@lecturer.FirstName</td>
            <td>@lecturer.LastName</td>
            <td>@lecturer.PhoneNumber</td>
            <td>@lecturer.Age</td>
            <td>
                <a href="/Lecturers/Edit/@lecturer.LecturerID" class="btn btn-primary btn-sm">Edit</a>
                <a href="/Lecturers/Delete/@lecturer.LecturerID"  class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>