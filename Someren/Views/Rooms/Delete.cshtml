@model Someren.Models.Room

@{
    ViewData["Title"] = "Delete room";
}


<h2>Delete room</h2>

@if (ViewData["ErrorMessage"] != null)
{
    <p>@ViewData["ErrorMessage"]</p>
}

<p>Are you sure you want to delete this room?</p>

<div class="mb-3">
    <strong>Room number:</strong> @Model.RoomNumber
</div>
<div class="mb-3">
    <strong>Floor:</strong> @Model.Floor
</div>
<div class="mb-3">
    <strong>Room size:</strong> @Model.BedsCapacity
</div>
<div class="mb-3">
    <strong>Type of room:</strong> @Model.RoomType
</div>
<div class="mb-3">
    <strong>Building:</strong> @Model.BuildingID
</div>

<form action="/Rooms/Delete" method="post">
    <input type="hidden" name="RoomID" value="@Model.RoomID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/Rooms/Index" class="btn btn-secondary">Back to list</a>
</form>