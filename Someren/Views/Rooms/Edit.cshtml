@model Someren.Models.Room

@{
    ViewData["Title"] = "Edit room";
}

<h2>Edit room</h2>

<form action="/Rooms/Edit" method="post">
    <input type="hidden" name="RoomID" value="@Model.RoomID" />

    <div class="mb-3">
        <label for="RoomNumber" class="form-label">Room number</label>
        <input type="text" id="RoomNumber" name="RoomNumber" class="form-control" value="@Model.RoomNumber" />
    </div>

    <div class="mb-3">
        <label for="RoomType" class="form-label">Type of room</label>
        <select name="RoomType" class="form-control" id="roomTypeSelect">
            @if (Model.RoomType == "student")
            {
                <option value="student" selected>student</option>
                <option value="lecturer">lecturer</option>
            }
            else
            {
                <option value="student">student</option>
                <option value="lecturer" selected>lecturer</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label for="Floor" class="form-label">Floor</label>
        <select name="Floor" class="form-control" id="floorSelect">
            @if (Model.Floor == 1)
            {
                <option value="1" selected>1</option>
                <option value="2">2</option>
            }
            else
            {
                <option value="1">1</option>
                <option value="2" selected>2</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label for="BedsCapacity" class="form-label">Room size</label>
        <input type="text" name="BedsCapacity" class="form-control" value="@Model.BedsCapacity" />
    </div>

    <div class="mb-3">
        <label for="BuildingID" class="form-label">Building</label>
        <select name="BuildingID" class="form-control" id="buildingIdInput">
            @if (Model.BuildingID == 1)
            {
                <option value="1" selected>A</option>
                <option value="2">B</option>
            }
            else
            {
                <option value="1">A</option>
                <option value="2" selected>B</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Save changes</button>
    <a href="/Rooms/Index" class="btn btn-secondary">Back to list</a>
</form>