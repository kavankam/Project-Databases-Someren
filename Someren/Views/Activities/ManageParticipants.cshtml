@model Someren.Models.ManageParticipantsModel

@{
    ViewData["Title"] = "Manage Participants";
}


<h2>Manage Participants</h2>

<h5 style="display: flex; justify-content: space-between; align-items: center;">
    <span>Activity: @Model.Activity.Name</span>

    <span id="flashMessage" style="color: green; font-weight: bold; font-size: 0.9rem; display: none;">
        @TempData["Message"]
    </span>
</h5>
<hr />

@section Scripts {
    <script>
        const flash = document.getElementById('flashMessage');

        function showFlash() {
            if (!flash) return;

            flash.style.display = 'inline';   // show the message
            clearTimeout(flash.timeout);       // clear previous timeout if it exists

            // hide after 2 seconds
            flash.timeout = setTimeout(() => {
                flash.style.display = 'none';
            }, 1000);
        }

        // If TempData has a message, show it
        @if (TempData["Message"] != null)
        {
                <text>showFlash();</text>
        }
    </script>
}

<div style="display: flex; gap: 50px;">

    <div>
        <h4>Students</h4>

        <table class="table">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Class</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model.NonParticipants)
                {
                    <tr>
                        <td>@student.FirstName</td>
                        <td>@student.LastName</td>
                        <td>@student.Class</td>
                        <td>
                            <form asp-action="AddParticipant" method="post">
                                <input type="hidden" name="activityId" value="@Model.Activity.ActivityID" />
                                <input type="hidden" name="studentId" value="@student.StudentID" />
                                <button type="submit" class="btn btn-success btn-sm">Add as participant</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div>
        <h4>Participants</h4>

        <table class="table">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Class</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var participant in Model.Participants)
                {
                    <tr>
                        <td>@participant.FirstName</td>
                        <td>@participant.LastName</td>
                        <td>@participant.Class</td>
                        <td>
                            <form asp-action="RemoveParticipant" method="post">
                                <input type="hidden" name="activityId" value="@Model.Activity.ActivityID" />
                                <input type="hidden" name="studentId" value="@participant.StudentID" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove as participant</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<br />

<a asp-action="Index" class="btn btn-secondary">Back to Activities</a>