@model Someren.Models.Activity

<h1>Delete Activity</h1>
<h3 class="text-danger">Are you sure you want to delete this?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Activity Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Scheduled Day</dt>
        <dd class="col-sm-10">@Model.Day.ToShortDateString()</dd>

        <dt class="col-sm-2">Time Slot</dt>
        <dd class="col-sm-10">@Model.TimeSlot.ToString(@"hh\:mm")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" name="id" value="@Model.ActivityID" />

        <input type="submit" value="Confirm Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>