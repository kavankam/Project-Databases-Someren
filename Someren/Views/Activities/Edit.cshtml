@model Someren.Models.Activity

@{
    ViewData["Title"] = "Edit Activity";
}

<h1>Edit Activity</h1>

<form action="/Activities/Edit" method="post">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="text-danger">Please fix the errors below.</div>
    }
    <input type="hidden" name="ActivityID" value="@Model.ActivityID" />
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Day</label>
        <input type="date" name="Day" value="@Model.Day.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Start Time</label>
        <input type="time" name="TimeSlot" value="@Model.TimeSlot.ToString(@"hh\:mm")" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Duration (minutes)</label>
        <input type="text" name="DurationMinutes" value="@Model.DurationMinutes" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Activities" class="btn btn-secondary">Back</a>
</form>
